# Copie ce fichier en .env et renseigne les valeurs. Le vrai .env n'est jamais commite.

# --- LLM (prototype : appel direct au provider) ---
# On demarre avec Groq (rapide, peu couteux) et OpenAI. Anthropic pour plus tard.
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Embeddings : tournent en local via sentence-transformers (gratuit).
# Token seulement necessaire pour un modele HuggingFace gated. Optionnel.
HUGGINGFACEHUB_API_TOKEN=

# --- API open data SNCF ---
# Cle du portail https://data.sncf.com (a recuperer en Semaine 0)
SNCF_API_KEY=

# --- Observabilite : LangSmith (Semaine 5) ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=sncf-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Version scalable (Semaine 6, extras [scale]) ---
QDRANT_URL=
QDRANT_API_KEY=
REDIS_URL=
# Gateway Portkey : unification et fallback des cles LLM.
# A configurer ENSEMBLE quand on activera le gateway (ne pas activer avant le signal).
PORTKEY_API_KEY=
